#!/bin/bash

VERSION="1.0.0"

if [ "$1" == "--version" ]; then
    echo "Dual Audio Manager v$VERSION"
    exit 0
fi

get_sinks() {
    pactl list short sinks | awk '{print $2}'
}

remove_combined() {
    MODULE_ID=$(pactl list short modules | grep module-combine-sink | awk '{print $1}')
    if [ -n "$MODULE_ID" ]; then
        pactl unload-module $MODULE_ID
        echo "Combined sink removed."
    else
        echo "No combined sink found."
    fi
}

set_single() {
    SINK=$(get_sinks | fzf --height=40% --layout=reverse --border --prompt="Select output: ")
    [ -z "$SINK" ] && exit 1

    remove_combined
    pactl set-default-sink "$SINK"
    echo "Switched to $SINK"
}

set_multi() {
    SINKS=$(get_sinks | fzf -m --height=60% --layout=reverse --border --prompt="Select devices (TAB to mark): ")
    [ -z "$SINKS" ] && exit 1

    SLAVES=$(echo "$SINKS" | paste -sd "," -)

    remove_combined
    pactl load-module module-combine-sink \
        sink_name=multi_output \
        slaves="$SLAVES"

    pactl set-default-sink multi_output

    echo "Combined:"
    echo "$SINKS"
}

# Shortcut remove
if [ "$1" == "-r" ]; then
    remove_combined
    exit 0
fi

# Arrow-key main menu
OPTION=$(printf "Single Output\nDual Output (2 devices)\nMulti Output (3+ devices)\nRemove Combined\nExit" | \
fzf --height=40% --layout=reverse --border --prompt="Select option: ")

case "$OPTION" in
    "Single Output")
        set_single
        ;;
    "Dual Output (2 devices)")
        set_multi
        ;;
    "Multi Output (3+ devices)")
        set_multi
        ;;
    "Remove Combined")
        remove_combined
        ;;
    *)
        exit 0
        ;;
esac
